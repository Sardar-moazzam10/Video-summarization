# ===================================================
# Video-summarization Environment Configuration
# Copy this file to .env and fill in your values
# ===================================================

# ==================== MongoDB ====================
# Option 1: MongoDB Atlas (cloud) - recommended for production
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/

# Option 2: Local MongoDB (Docker or installed)
# MONGODB_URI=mongodb://localhost:27017/

# Database name
MONGODB_DATABASE=user-auth

# ==================== Email (Gmail SMTP) ====================
# For Gmail, use an App Password (not your regular password)
# Create one at: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ==================== ElevenLabs API (Voiceover) ====================
# Sign up at https://elevenlabs.io/ to get your API key
ELEVEN_API_KEY=sk_your_api_key_here

# ==================== Demo/Dev Mode ====================
DEMO_MODE=0

# ==================== Video Cache Settings ====================
VIDEO_CACHE_ENABLED=1
VIDEO_CACHE_MAX_SIZE_GB=10
VIDEO_CACHE_MAX_AGE_DAYS=30
MAX_PARALLEL_DOWNLOADS=2
DOWNLOAD_RETRY_ATTEMPTS=3

# ==================== Cleanup Settings ====================
ENABLE_AUTO_CLEANUP=1
CLEANUP_INTERVAL_HOURS=1
TEMP_DIR_MAX_AGE_HOURS=24
TRANSCRIPTION_TEMP_MAX_AGE_HOURS=1

# ==================== Whisper/Transcription ====================
WHISPER_ALLOW_PARALLEL=0

# ==================== External Tools (Optional) ====================
# FFMPEG_PATH=/usr/bin/ffmpeg
# YTDLP_PATH=/usr/bin/yt-dlp
